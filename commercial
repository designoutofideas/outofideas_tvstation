<script>
// UTC clock
function tick(){
  const n=new Date();
  document.getElementById('utc-clock').textContent=
    String(n.getUTCHours()).padStart(2,'0')+':'+
    String(n.getUTCMinutes()).padStart(2,'0')+':'+
    String(n.getUTCSeconds()).padStart(2,'0');
}
setInterval(tick,1000);tick();

// Profile switcher
function setProfile(p,el){
  document.querySelectorAll('.profile-content').forEach(e=>e.classList.remove('active'));
  document.querySelectorAll('.profile-tab').forEach(e=>e.classList.remove('active'));
  document.getElementById('profile-'+p).classList.add('active');
  el.classList.add('active');
}

// Architecture explorer
function setArch(id,el){
  document.querySelectorAll('.arch-panel').forEach(e=>e.classList.remove('active'));
  document.querySelectorAll('.arch-nav-item').forEach(e=>e.classList.remove('active'));
  document.getElementById('arch-'+id).classList.add('active');
  el.classList.add('active');
}

// Block schedule demo
const BLOCKS=[
  {name:'LATE NIGHT',start:0,end:3,files:['ambient-vol1','space-drift'],dur:[1800,2400]},
  {name:'SLEEP',start:3,end:7,files:['sleep-tones'],dur:[3600]},
  {name:'WAKE',start:7,end:9,files:['morning-rise','gentle-start'],dur:[1200,900]},
  {name:'MORNING',start:9,end:12,files:['news-block','culture-am','feature-01'],dur:[1800,2700,1200]},
  {name:'NOON',start:12,end:14,files:['midday-mix','spotlight'],dur:[3600,1800]},
  {name:'AFTERNOON',start:14,end:18,files:['documentary','short-film','culture-pm'],dur:[3600,2400,1800]},
  {name:'EVENING',start:18,end:21,files:['prime-show','evening-news'],dur:[5400,1800]},
  {name:'NIGHT',start:21,end:24,files:['late-show','night-culture','deep-cuts'],dur:[3600,2700,1800]}
];

function buildBlocks(){
  const g=document.getElementById('block-grid');g.innerHTML='';
  const h=new Date().getUTCHours();
  BLOCKS.forEach(b=>{
    const d=document.createElement('div');
    d.className='demo-block'+(h>=b.start&&h<b.end?' active-block':'');
    d.innerHTML='<div class="demo-block-name">'+b.name+'</div><div class="demo-block-time">'+
      String(b.start).padStart(2,'0')+':00–'+String(b.end).padStart(2,'0')+':00</div>';
    g.appendChild(d);
  });
}

function simHash(s){
  let h=0;for(let i=0;i<s.length;i++){h=((h<<5)-h)+s.charCodeAt(i);h|=0;}
  return Math.abs(h).toString(16).padStart(12,'0').substring(0,12);
}

function updateDemo(){
  const n=new Date();
  const h=n.getUTCHours(),m=n.getUTCMinutes(),s=n.getUTCSeconds();
  const total=h*3600+m*60+s;
  const block=BLOCKS.find(b=>h>=b.start&&h<b.end)||BLOCKS[0];
  const elapsed=total-(block.start*3600);
  const tdur=block.dur.reduce((a,b)=>a+b,0);
  const pos=elapsed%tdur;
  let acc=0,qi=0,off=0;
  for(let i=0;i<block.dur.length;i++){if(pos<acc+block.dur[i]){qi=i;off=pos-acc;break;}acc+=block.dur[i];}
  const interval=Math.floor(Date.now()/1000/3600);
  const token=simHash('tvstation_'+interval);
  const viewers=Math.floor(12400+Math.sin(Date.now()/28000)*4200+Math.random()*150);
  document.getElementById('dc-utc').textContent=String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0')+' UTC';
  document.getElementById('dc-block').textContent=block.name+' ('+block.start+':00 – '+block.end+':00)';
  document.getElementById('dc-elapsed').textContent=elapsed+'s ('+Math.floor(elapsed/60)+'m '+elapsed%60+'s)';
  document.getElementById('dc-queue').textContent='file '+(qi+1)+' of '+block.files.length+' — '+block.files[qi];
  document.getElementById('dc-offset').textContent=off+'s into file';
  document.getElementById('dc-token').textContent=token;
  document.getElementById('demo-url').textContent='channel.tvstation.io/'+token+'/'+block.name.toLowerCase().replace(' ','-');
  document.getElementById('dc-viewers').textContent=viewers.toLocaleString();
  document.querySelectorAll('.demo-block').forEach((el,i)=>{el.classList.toggle('active-block',BLOCKS[i]===block);});
}

buildBlocks();updateDemo();setInterval(updateDemo,1000);

// Language switcher
const L={
  en:{eyebrow:'PROPRIETARY BROADCAST TECHNOLOGY',title:'ZERO<br>LOAD.<br><span style="color:var(--green)">INFINITE</span><br>SCALE.',sub:'A broadcast delivery system where publisher infrastructure load does not increase with audience size. Every viewer receives the same content at the same moment — without server-side coordination, without scaling costs, without limits.',s1:'ADDED LOAD PER VIEWER',s2:'CONCURRENT VIEWERS',s3:'GLOBAL TIME SOURCE',sync:'ALL CONNECTED VIEWERS SYNCHRONIZED'},
  es:{eyebrow:'TECNOLOGÍA DE DIFUSIÓN PROPIETARIA',title:'CERO<br>CARGA.<br><span style="color:var(--green)">ESCALA</span><br>INFINITA.',sub:'Un sistema de entrega donde la carga de infraestructura no aumenta con el tamaño de la audiencia.',s1:'CARGA ADICIONAL POR ESPECTADOR',s2:'ESPECTADORES SIMULTÁNEOS',s3:'FUENTE DE TIEMPO GLOBAL',sync:'TODOS LOS ESPECTADORES SINCRONIZADOS'},
  zh:{eyebrow:'专有广播技术',title:'零<br>负载.<br><span style="color:var(--green)">无限</span><br>扩展.',sub:'一种广播传输系统，发布商基础设施负载不随受众规模增加。每位观众在同一时刻收到相同内容。',s1:'每位观众的额外负载',s2:'并发观看人数',s3:'全球时间源',sync:'所有连接的观众已同步'},
  ja:{eyebrow:'独自の放送技術',title:'ゼロ<br>負荷.<br><span style="color:var(--green)">無限の</span><br>スケール.',sub:'視聴者数が増えても発行者のインフラ負荷が増加しない放送配信システム。',s1:'視聴者ごとの追加負荷',s2:'同時視聴者数',s3:'グローバル時刻ソース',sync:'すべての視聴者が同期されています'}
};
function setLang(l,el){
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  const d=L[l];
  document.getElementById('h-eyebrow').textContent=d.eyebrow;
  document.getElementById('h-title').innerHTML=d.title;
  document.getElementById('h-sub').textContent=d.sub;
  document.getElementById('h-s1').textContent=d.s1;
  document.getElementById('h-s2').textContent=d.s2;
  document.getElementById('h-s3').textContent=d.s3;
  document.getElementById('h-sync').textContent=d.sync;
}
